rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      ) || request.auth.token.email == 'durgeshpuri95@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 8 && // Allowing optional fields like 'course' and 'status'
             data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['admin', 'student'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && 
                    isValidId(userId) && 
                    isOwner(userId) && 
                    isValidUser(incoming()) && 
                    incoming().uid == userId && 
                    incoming().createdAt == request.time && 
                    incoming().updatedAt == request.time &&
                    (incoming().role == 'student' || isAdmin()); // Only admin can create another admin

      allow update: if isSignedIn() && 
                    isValidId(userId) && 
                    isValidUser(incoming()) && 
                    (
                      // Admin can update anything
                      isAdmin() ||
                      // Students can update their own profile but NOT their role or status
                      (isOwner(userId) && 
                       incoming().role == existing().role &&
                       incoming().status == existing().status &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'course', 'updatedAt'])
                      )
                    );
      
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }
  }
}
